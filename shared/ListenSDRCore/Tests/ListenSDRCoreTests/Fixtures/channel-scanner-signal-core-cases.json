{
  "defaultThresholdCases": [
    {
      "label": "fm-dx default threshold",
      "backend": "fmDxWebserver",
      "expected": 20.0
    },
    {
      "label": "kiwi default threshold",
      "backend": "kiwiSDR",
      "expected": -95.0
    },
    {
      "label": "openwebrx default threshold",
      "backend": "openWebRX",
      "expected": -42.0
    }
  ],
  "signalUnitCases": [
    {
      "label": "fm-dx uses dbf",
      "backend": "fmDxWebserver",
      "expected": "dBf"
    },
    {
      "label": "kiwi uses dbm",
      "backend": "kiwiSDR",
      "expected": "dBm"
    },
    {
      "label": "openwebrx uses dbfs",
      "backend": "openWebRX",
      "expected": "dBFS"
    },
    {
      "label": "missing backend falls back to db",
      "backend": null,
      "expected": "dB"
    }
  ],
  "adaptiveDwellCases": [
    {
      "label": "non adaptive dwell stays unchanged",
      "base": 1.5,
      "adaptive": false,
      "signal": 15.0,
      "threshold": 5.0,
      "expected": 1.5
    },
    {
      "label": "missing signal shortens dwell conservatively",
      "base": 1.5,
      "adaptive": true,
      "signal": null,
      "threshold": 5.0,
      "expected": 1.125
    },
    {
      "label": "strong signal extends dwell",
      "base": 1.5,
      "adaptive": true,
      "signal": 15.0,
      "threshold": 5.0,
      "expected": 2.175
    },
    {
      "label": "weak signal shortens dwell aggressively",
      "base": 1.5,
      "adaptive": true,
      "signal": -20.0,
      "threshold": -10.0,
      "expected": 0.87
    }
  ],
  "adaptiveHoldCases": [
    {
      "label": "non adaptive hold stays unchanged",
      "base": 4.0,
      "adaptive": false,
      "signal": 18.0,
      "threshold": 6.0,
      "expected": 4.0
    },
    {
      "label": "missing signal shortens hold conservatively",
      "base": 4.0,
      "adaptive": true,
      "signal": null,
      "threshold": 6.0,
      "expected": 2.8
    },
    {
      "label": "strong signal extends hold",
      "base": 4.0,
      "adaptive": true,
      "signal": 18.0,
      "threshold": 6.0,
      "expected": 10.4
    },
    {
      "label": "small margin shortens hold",
      "base": 4.0,
      "adaptive": true,
      "signal": 7.0,
      "threshold": 6.0,
      "expected": 3.12
    }
  ],
