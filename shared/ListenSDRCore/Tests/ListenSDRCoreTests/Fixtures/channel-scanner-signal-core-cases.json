      "label": "low frequency hum is rejected",
      "profile": "gentle",
      "metrics": {
        "sampleAgeSeconds": 0.2,
        "analysisBufferCount": 4,
        "envelopeVariation": 0.3,
        "zeroCrossingRate": 0.02,
