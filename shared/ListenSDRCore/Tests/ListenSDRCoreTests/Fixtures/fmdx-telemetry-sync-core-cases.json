{
  "toggleCases": [
    {
      "label": "auto resolves to enabled",
      "input": "auto",
      "expected": true
    },
    {
      "label": "agc resolves to enabled",
      "input": "agc",
      "expected": true
    },
    {
      "label": "manual resolves to disabled",
      "input": "manual",
      "expected": false
    },
    {
      "label": "man resolves to disabled",
      "input": "man",
      "expected": false
    },
    {
      "label": "unknown token stays unresolved",
      "input": "maybe",
      "expected": null
    },
    {
      "label": "nil token stays unresolved",
      "input": null,
      "expected": null
    }
  ],
  "bandwidthSelectionCases": [
    {
      "label": "exact bandwidth id is kept",
      "rawValue": "wide",
      "capabilities": [
        {
          "id": "wide",
          "legacyValue": "110000"
        }
      ],
      "expected": "wide"
    },
    {
      "label": "legacy bandwidth id maps to canonical id",
      "rawValue": "150000",
      "capabilities": [
        {
          "id": "narrow",
          "legacyValue": "150000"
        }
      ],
      "expected": "narrow"
    },
    {
      "label": "unknown bandwidth id is preserved",
      "rawValue": "custom",
      "capabilities": [
        {
          "id": "wide",
          "legacyValue": "110000"
        }
      ],
      "expected": "custom"
    }
  ],
