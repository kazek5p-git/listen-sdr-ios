{
  "profileCases": [
    {
      "label": "fmdx oirt profile keeps oirt stepping",
      "context": {
        "backend": "fmDxWebserver",
        "frequencyHz": 70300000,
        "mode": "fm",
        "bandName": null,
        "bandTags": []
      },
      "expectedProfile": {
        "id": "fmdx-oirt-fm",
        "stepOptionsHz": [10000, 25000, 30000, 50000, 100000],
